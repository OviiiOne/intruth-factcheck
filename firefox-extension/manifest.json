{
  "manifest_version": 2,
  "name": "InTruth",
  "version": "2.3.1",
  "description": "Press-conference companion: live transcription, translation, neutral key points and on-demand summaries (ES/EN)",
  "homepage_url": "https://github.com/OviiiOne/intruth-factcheck",

  "browser_specific_settings": {
    "gecko": {
      "id": "intruth@intruth.dev",
      "strict_min_version": "109.0"
    }
  },

  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "<all_urls>"
  ],

  "background": {
    "scripts": ["src/lib/lang.js", "src/background/background.js"]
  },

  "browser_action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "js": [
        "src/lib/lang.js",
        "src/content/lexical-features.js",
        "src/content/session-export.js",
        "src/content/audio-capture.js",
        "src/content/overlay.js"
      ],
      "css": ["src/content/overlay.css"]
    }
  ],

  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },

  "content_security_policy": "script-src 'self' https://cdn.jsdelivr.net; object-src 'self';"
}
